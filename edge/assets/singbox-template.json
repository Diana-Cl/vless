{
  "dns": {
    "final": "proxy-dns",
    "rules": [
      {
        "clash_mode": "Global",
        "server": "proxy-dns",
        "source_ip_cidr": ["172.19.0.0/30"]
      },
      {
        "server": "proxy-dns",
        "source_ip_cidr": ["172.19.0.0/30"]
      },
      {
        "clash_mode": "Direct",
        "server": "direct-dns"
      },
      {
        "rule_set": ["geosite-ir"],
        "server": "direct-dns"
      }
    ],
    "servers": [
      {
        "type": "tcp",
        "tag": "proxy-dns",
        "server": "185.228.168.9",
        "domain_resolver": "local-dns",
        "detour": "proxy"
      },
      {
        "type": "tcp",
        "tag": "local-dns",
        "server": "8.8.4.4",
        "detour": "direct"
      },
      {
        "type": "local",
        "tag": "direct-dns",
        "detour": "direct"
      }
    ],
    "strategy": "prefer_ipv4"
  },
  "endpoints": [],
  "inbounds": [
      {
      "type": "direct",
      "tag": "dns-in",
      "listen": "0.0.0.0",
      "listen_port": 6450,
      "override_address": "1.1.1.1",
      "override_port": 53
      },
      {
      "type": "tun",
      "tag": "tun-in",
      "address": [
          "172.18.0.1/28",
          "fdfe:dcba:9876::1/126"
      ],
      "mtu": 1500,
      "auto_route": true,
      "endpoint_independent_nat": true,
      "stack": "mixed"
      },
      {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "0.0.0.0",
      "listen_port": 2080
      }
    ],
  "outbounds": [
    {
      "tag": "proxy",
      "type": "selector",
      "outbounds": ["wg_tehran", "wg_berlin"],
      "default": "wg_berlin",
      "interrupt_exist_connections": false
    },
    {
      "tag": "auto",
      "type": "urltest",
      "outbounds": ["wg_tehran", "wg_berlin"],
      "tolerance": 50,
      "url": "https://www.gstatic.com/generate_204"
    },
    {
      "tag": "direct",
      "domain_strategy": "prefer_ipv4",
      "type": "direct"
    }
  ],
  "route": {
    "auto_detect_interface": true,
    "override_android_vpn": true,
    "final": "proxy",
    "rule_set": [
      {
        "tag": "geosite-ads",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/category-ads-all.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geosite-private",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/private.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geosite-ir",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/category-ir.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geoip-private",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/private.srs",
        "download_detour": "direct"
      },
      {
        "tag": "geoip-ir",
        "type": "remote",
        "format": "binary",
        "url": "https://testingcf.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/ir.srs",
        "download_detour": "direct"
      }
    ],
    "rules": [
      {
        "action": "sniff",
        "timeout": "1s"
      },
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      {
        "clash_mode": "Direct",
        "action": "resolve",
        "strategy": "prefer_ipv4"
      },
      {
        "clash_mode": "Global",
        "action": "route-options",
        "override_address": "1.1.1.1",
        "override_port": 443
      },
      {
        "rule_set": ["geoip-private", "geosite-private", "geosite-ir", "geoip-ir"],
        "action": "direct"
      },
      {
        "rule_set": ["geosite-ads"],
        "action": "reject"
      }
    ]
  }
}
