{
  "$schema": "https://biomejs.dev/schemas/1.5.3/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "ignore": [
      "node_modules",
      "dist",
      "build",
      ".git",
      "warp.json",
      "sub/",
      "edge/waste",
      "DNS over HTTPS/",
      "boringtun-boringtun-cli-0.5.2/",
      "Hiddify/",
      "packag.json",
      "package-lock.json",
      "*.min.js",
      "coverage"
    ]
  }
}
